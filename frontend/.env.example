# =============================================================================
# athletIQ — Frontend Configuration
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs.
# IMPORTANT : le MVP week-end n'utilise plus Render/FastAPI pour le flux normal.
# =============================================================================

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Strava (optionnel, utilise pour le bouton "Connect with Strava") ---
VITE_STRAVA_CLIENT_ID=<votre-strava-client-id>

# --- MapTiler (carte GPS des activités) ---
VITE_MAPTILER_API_KEY=your_maptiler_api_key_here

# --- Sentry (optionnel, vide = desactive) ---
# DSN fourni par Sentry lors de la creation du projet frontend
VITE_SENTRY_DSN=
