# Worker de prédiction (2e Mac) — configuration
# Copie en .env et remplis (NE PAS committer .env).

# Supabase (même projet que le relais Garmin)
SUPABASE_URL=https://rjojtypjmykfkgnndamt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# user_id HISTORIQUE dans stridedelta.db (andre.bertea92@gmail.com).
# Le moteur calibre sur les 280 activités de CE user.
OLD_USER_ID=b5727f6086db41ab86e2bc803460b868

# Optionnel : mapping JSON Supabase user_id -> ancien user_id (multi-athlète).
# Si vide, OLD_USER_ID s'applique à tous les jobs.
# PREDICT_USER_MAP={"<supabase_uuid>":"<old_uuid>"}

# Chemin de la base historique (défaut: <repo>/backend/stridedelta.db si non fourni)
# PREDICT_DB_PATH=/Users/<toi>/athletIQ/backend/stridedelta.db

# Variables requises par les settings du backend (valeurs bidons, non utilisées ici)
JWT_SECRET_KEY=predict-worker-local
STRAVA_CLIENT_ID=0
ENCRYPTION_KEY=predict-worker-local

# Optionnel
PREDICT_POLL_INTERVAL=3
